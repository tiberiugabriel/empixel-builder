---
import type { ImageConfig } from "../types.js";
import { buildBlockChromeCss } from "./styleUtils.js";
import { resolveMediaUrl, resolveResponsiveSrcSet } from "./media.js";

interface Props {
  value: ImageConfig;
  blockId?: string;
}

const RESOLUTION_DIMS: Record<string, { w: number; h: number }> = {
  thumbnail: { w: 150,  h: 150  },
  medium:    { w: 300,  h: 300  },
  large:     { w: 1024, h: 1024 },
};

const ALIGN_TO_JUSTIFY: Record<string, string> = {
  start:  "flex-start",
  center: "center",
  end:    "flex-end",
};

const { value: rawValue, blockId } = Astro.props as { value?: ImageConfig; blockId?: string };
const value: ImageConfig = rawValue ?? {};
const { image, resolution = "full", caption = "" } = value;

const advanced = (value as Record<string, unknown>).advanced as Record<string, string> | undefined;
const cssId      = advanced?.cssId      || undefined;
const cssClasses = advanced?.cssClasses || undefined;

const cfg = value as Record<string, unknown>;
const linkHref       = (cfg.linkHref       as string)  || undefined;
const linkNewTab     = (cfg.linkNewTab     as boolean) || false;
const linkNofollow   = (cfg.linkNofollow   as boolean) || false;
const linkCustomAttr = (cfg.linkCustomAttr as string)  || "";
const linkTarget = linkNewTab ? "_blank" : undefined;
const linkRel = (() => {
  const parts: string[] = [];
  if (linkNewTab)   parts.push("noopener", "noreferrer");
  if (linkNofollow) parts.push("nofollow");
  return parts.length ? parts.join(" ") : undefined;
})();
const linkCustomAttrs: Record<string, string> = {};
if (linkCustomAttr) {
  for (const pair of linkCustomAttr.split(",")) {
    const sep = pair.indexOf("|");
    if (sep > 0) {
      const k = pair.slice(0, sep).trim();
      const v = pair.slice(sep + 1).trim();
      if (k) linkCustomAttrs[k] = v;
    }
  }
}

const dims = RESOLUTION_DIMS[resolution];
const imgWidthAttr  = dims?.w;
const imgHeightAttr = dims?.h;
// Storage-agnostic URL resolution (F2.2). The plugin persists `storageKey`
// references in layout JSON; EmDash's active storage adapter (local/S3/R2)
// turns those into fetchable URLs via Astro.locals.emdash.getPublicMediaUrl.
const imgSrc = resolveMediaUrl(image?.storageKey, { locals: Astro.locals }) ?? undefined;
const imgAlt = image?.alt ?? image?.filename ?? "";

// F4.10 — responsive `<picture>` markup. `resolveResponsiveSrcSet`
// returns null when the host's storage adapter doesn't support format
// conversion (local-runtime fallback, missing `getPublicMediaUrl`, or
// falsy key) — in that case we degrade to a plain `<img>` and the
// pre-F4.10 behavior is preserved verbatim. When non-null, we emit
// `<picture>` with AVIF + WebP `<source>` elements and an
// `<img srcset>` fallback so browsers/CDNs that honor format query
// params (Cloudflare Image Resizing, Vercel/Netlify image
// optimization, etc.) download the smallest appropriate file.
const responsive = resolveResponsiveSrcSet(image?.storageKey, { locals: Astro.locals });

const imgStyleCfg = (cfg.imgStyle ?? {}) as Record<string, string | undefined>;
const imgInline = (() => {
  const out: string[] = [];
  const keys: Array<[string, string]> = [
    ["width",          "width"],
    ["minWidth",       "min-width"],
    ["maxWidth",       "max-width"],
    ["height",         "height"],
    ["minHeight",      "min-height"],
    ["maxHeight",      "max-height"],
    ["objectFit",      "object-fit"],
    ["objectPosition", "object-position"],
  ];
  for (const [k, css] of keys) {
    const v = (imgStyleCfg[k] || "").trim();
    if (v) out.push(`${css}:${v}`);
  }
  return out.join(";");
})();

const config = value as Record<string, unknown>;
const resolver = (key: string) => resolveMediaUrl(key, { locals: Astro.locals });
const chromeCss = buildBlockChromeCss(config, blockId, {
  imgScoped: true,
  resolveMediaUrl: resolver,
});

const styleCfg = (cfg.style ?? {}) as Record<string, string | undefined>;
const alignVal = (styleCfg.textAlign || "").trim();
const justify  = ALIGN_TO_JUSTIFY[alignVal];
const frameCss = blockId && justify
  ? `[data-epx-block="${blockId}"] > .epx-img-frame{display:flex;justify-content:${justify};}`
  : "";

const allCss = [chromeCss, frameCss].filter(Boolean).join("");

const RootTag = ((caption ? "figure" : (linkHref ? "a" : "div")) as astroHTML.JSX.HTMLTag);
const rootIsLink = RootTag === "a";
---

{imgSrc ? (
  <RootTag
    data-epx-block={blockId || undefined}
    id={cssId}
    class={cssClasses || undefined}
    href={rootIsLink ? linkHref : undefined}
    target={rootIsLink ? linkTarget : undefined}
    rel={rootIsLink ? linkRel : undefined}
    {...(rootIsLink ? linkCustomAttrs : {})}
  >
    <div class="epx-img-frame">
      {caption && linkHref ? (
        <a href={linkHref} target={linkTarget} rel={linkRel} {...linkCustomAttrs}>
          {responsive ? (
            <picture>
              <source type="image/avif" srcset={responsive.avif} sizes={responsive.sizes} />
              <source type="image/webp" srcset={responsive.webp} sizes={responsive.sizes} />
              <img src={imgSrc} srcset={responsive.fallback} sizes={responsive.sizes} alt={imgAlt} width={imgWidthAttr} height={imgHeightAttr} style={imgInline || undefined} loading="lazy" decoding="async" />
            </picture>
          ) : (
            <img src={imgSrc} alt={imgAlt} width={imgWidthAttr} height={imgHeightAttr} style={imgInline || undefined} loading="lazy" decoding="async" />
          )}
        </a>
      ) : (
        responsive ? (
          <picture>
            <source type="image/avif" srcset={responsive.avif} sizes={responsive.sizes} />
            <source type="image/webp" srcset={responsive.webp} sizes={responsive.sizes} />
            <img src={imgSrc} srcset={responsive.fallback} sizes={responsive.sizes} alt={imgAlt} width={imgWidthAttr} height={imgHeightAttr} style={imgInline || undefined} loading="lazy" decoding="async" />
          </picture>
        ) : (
          <img src={imgSrc} alt={imgAlt} width={imgWidthAttr} height={imgHeightAttr} style={imgInline || undefined} loading="lazy" decoding="async" />
        )
      )}
    </div>
    {caption && <figcaption>{caption}</figcaption>}
  </RootTag>
) : null}

{imgSrc && allCss && <style set:html={allCss} is:global />}
