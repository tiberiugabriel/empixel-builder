---
import type { HtmlConfig } from "../types.js";
import { buildBlockChromeCss } from "./styleUtils.js";
import { resolveMediaUrl } from "./media.js";

interface Props {
  value: HtmlConfig;
  blockId?: string;
}

const { value, blockId } = Astro.props;
const cfg = value as Record<string, unknown>;

const advanced = cfg.advanced as Record<string, string> | undefined;
const cssId = advanced?.cssId || undefined;
const cssClasses = advanced?.cssClasses || undefined;

const rawCode = value.code ?? "";
const frameId = blockId ?? `epx-html-${Math.random().toString(36).slice(2, 9)}`;

// F4.8 — inline measure script that runs INSIDE the iframe and posts
// document.documentElement.scrollHeight to the parent on load / resize /
// MutationObserver content changes. Replaces the v0.6 DOM polling that
// required `allow-same-origin` to read scrollHeight from the parent side.
// With this protocol the sandbox can drop `allow-same-origin` (untrusted
// HTML loses access to parent.document/parent.location entirely) while
// auto-resize still works cross-origin via postMessage.
//
// Block-id is interpolated into the script string at SSR time so the
// parent listener can disambiguate when multiple HTML blocks share a
// page. Parent matches by `e.source === iframe.contentWindow` (canonical),
// the id is a secondary correlation hint for debugging.
function buildMeasureScript(id: string): string {
  // JSON.stringify guards against `</script>` injection in the id.
  const idJson = JSON.stringify(id);
  return [
    "<script>",
    "(function(){",
    "function send(){",
    "try{",
    "var h=document.documentElement.scrollHeight;",
    `parent.postMessage({type:"epx:html:resize",height:h,id:${idJson}},"*");`,
    "}catch(e){}",
    "}",
    'window.addEventListener("load",send);',
    'window.addEventListener("resize",send);',
    'if(document.body){new MutationObserver(send).observe(document.body,{subtree:true,childList:true,characterData:true});}',
    "send();",
    "})();",
    "</script>",
  ].join("");
}

function buildSrcdoc(code: string, id: string): string {
  const measureScript = buildMeasureScript(id);
  const hasFullDoc = /<html[\s>]/i.test(code);
  if (hasFullDoc) {
    // Inject the measure script before </body> if present, else append.
    if (/<\/body>/i.test(code)) {
      return code.replace(/<\/body>/i, `${measureScript}</body>`);
    }
    return `${code}${measureScript}`;
  }
  return `<!DOCTYPE html><html><head><meta charset="utf-8"><style>html,body{margin:0;padding:0;}</style></head><body>${code}${measureScript}</body></html>`;
}

const srcdoc = buildSrcdoc(rawCode, frameId);

const resolver = (key: string) => resolveMediaUrl(key, { locals: Astro.locals });
const chromeCss = buildBlockChromeCss(cfg, blockId, { resolveMediaUrl: resolver });

// Hard-override sizing so the iframe always takes full width regardless of
// surrounding flex/grid context, has no border, and has no internal scroll.
const iframeOverrideCss = `iframe[data-epx-html-frame]{display:block;width:100%;max-width:100%;border:none!important;outline:none;flex:1 1 100%;align-self:stretch;min-width:0;box-sizing:border-box;}`;

const allCss = [iframeOverrideCss, chromeCss].filter(Boolean).join("");
---

<iframe
  data-epx-block={blockId || undefined}
  id={cssId}
  class={cssClasses || undefined}
  data-epx-html-frame={frameId}
  sandbox="allow-scripts"
  scrolling="no"
  srcdoc={srcdoc}
  frameborder="0"
  style="display:block;width:100%;border:none;height:0;"
/>

<script is:inline>
  // F4.8 — postMessage auto-resize listener.
  // Replaces the v0.6 DOM-polling watcher. The iframe's inline measure
  // script (injected into srcdoc by Html.astro frontmatter) posts
  // { type: "epx:html:resize", height, id } on load / resize /
  // MutationObserver content changes. We listen, match by source ===
  // iframe.contentWindow (canonical — under `allow-scripts` only the
  // iframe's origin is "null" so origin checks are not meaningful), and
  // set the iframe's height inline.
  (function(){
    if (window.__epxHtmlPostMsg) return;
    window.__epxHtmlPostMsg = true;

    window.addEventListener("message", function(e){
      var data = e.data;
      if (!data || typeof data !== "object") return;
      if (data.type !== "epx:html:resize") return;
      var h = data.height;
      if (typeof h !== "number" || !isFinite(h) || h <= 0) return;
      var frames = document.querySelectorAll("iframe[data-epx-html-frame]");
      for (var i=0;i<frames.length;i++){
        var f = frames[i];
        if (f.contentWindow === e.source) {
          f.style.height = h + "px";
          return;
        }
      }
    });
  })();
</script>

{allCss && <style set:html={allCss} is:global />}

