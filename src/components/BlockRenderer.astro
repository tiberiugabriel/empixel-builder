---
import type { SectionBlock } from "../types.js";
import Text from "./Text.astro";
import ImageBlock from "./Image.astro";
import TextEditor from "./TextEditor.astro";
import Video from "./Video.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import Html from "./Html.astro";
import DividerSpacer from "./DividerSpacer.astro";

interface Props {
  block: SectionBlock;
}

const { block } = Astro.props;

// Single dispatch — every leaf block component is self-contained: it owns
// its own semantic root tag and emits data-epx-block + advanced.cssId +
// advanced.cssClasses + the full CSS bundle (block + hover + breakpoint +
// breakpoint-hover + custom) via buildBlockChromeCss in styleUtils.ts.
// HTML block stays special only because the iframe IS the data-epx-block
// element (not a wrapper around an iframe) — but it follows the same chrome
// contract internally. See audit H2.
//
// Legacy `testimonials` / `faq` / `pricing` blocks (removed) are silently
// ignored — no branch matches their type so nothing renders. Old layouts
// will still load; the orphan entries persist in the JSON until next save.
---

{block.type === "text" && (
  <Text value={block.config} blockId={block.id} />
)}

{block.type === "image" && (
  <ImageBlock value={block.config} blockId={block.id} />
)}

{block.type === "text-editor" && (
  <TextEditor value={block.config} blockId={block.id} />
)}

{block.type === "video" && (
  <Video value={block.config} blockId={block.id} />
)}

{block.type === "button" && (
  <Button value={block.config} blockId={block.id} />
)}

{block.type === "icon" && (
  <Icon value={block.config} blockId={block.id} />
)}

{block.type === "html" && (
  <Html value={block.config} blockId={block.id} />
)}

{block.type === "divider-spacer" && (
  <DividerSpacer value={block.config} blockId={block.id} />
)}
