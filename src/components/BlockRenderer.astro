---
import type { SectionBlock } from "../types.js";
import Testimonials from "./Testimonials.astro";
import FaqSection from "./FaqSection.astro";
import PricingSection from "./PricingSection.astro";
import Text from "./Text.astro";
import ImageBlock from "./Image.astro";
import TextEditor from "./TextEditor.astro";
import Video from "./Video.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import Html from "./Html.astro";
import DividerSpacer from "./DividerSpacer.astro";
import { buildBlockCss, buildHoverCss, getVideoBackground, getBlockId, getBlockClass, getCustomCss } from "./styleUtils.js";

// eslint-disable-next-line @typescript-eslint/no-explicit-any
const LEAF_COMPONENTS: Record<string, any> = {
  testimonials: Testimonials,
  faq: FaqSection,
  pricing: PricingSection,
};

interface Props {
  block: SectionBlock;
}

const { block } = Astro.props;
const Component = LEAF_COMPONENTS[block.type];

const config      = block.config as Record<string, unknown>;
const blockCss    = buildBlockCss(config, block.id);
const videoSrc    = getVideoBackground(config);
const blockId     = getBlockId(config);
const extraClass  = getBlockClass(config);
const customCss   = getCustomCss(config, block.id);
const hoverCss    = buildHoverCss(config, block.id);
const allCss      = [blockCss, hoverCss, customCss].filter(Boolean).join("");
---

{block.type === "text" && (
  <Text value={block.config} blockId={block.id} />
)}

{block.type === "image" && (
  <ImageBlock value={block.config} blockId={block.id} />
)}

{block.type === "text-editor" && (
  <TextEditor value={block.config} blockId={block.id} />
)}

{block.type === "video" && (
  <Video value={block.config} blockId={block.id} />
)}

{block.type === "button" && (
  <Button value={block.config} blockId={block.id} />
)}

{block.type === "icon" && (
  <Icon value={block.config} blockId={block.id} />
)}

{block.type === "html" && (
  <Html value={block.config} blockId={block.id} />
)}

{block.type === "divider-spacer" && (
  <DividerSpacer value={block.config} blockId={block.id} />
)}

{Component && (
  <div
    data-epx-block={block.id}
    id={blockId ?? undefined}
    class={extraClass || undefined}
  >
    {videoSrc && (
      <video
        autoplay
        muted
        loop
        playsinline
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;z-index:0;pointer-events:none;"
        src={videoSrc}
      />
    )}
    <div style={videoSrc ? "position:relative;z-index:1;" : undefined}>
      <Component value={block.config} />
    </div>
  </div>
)}

{Component && allCss && <style set:html={allCss} is:global />}
