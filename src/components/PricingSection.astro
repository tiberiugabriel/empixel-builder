---
import type { PricingConfig } from "../types.js";
import { parseItems } from "../types.js";

interface Props {
  value: PricingConfig;
}

const { value } = Astro.props;
const { headline, subheadline, theme = "light" } = value;
const tiers = parseItems(value.tiers);
---

<section class={`epx-pricing epx-theme--${theme}`}>
  <div class="epx-container">
    {(headline || subheadline) && (
      <div class="epx-section-header">
        {headline && <h2 class="epx-section-title">{headline}</h2>}
        {subheadline && <p class="epx-section-subtitle">{subheadline}</p>}
      </div>
    )}
    <div class="epx-pricing__grid">
      {tiers.map((tier) => (
        <div class={`epx-pricing-card ${tier.highlighted ? "is-highlighted" : ""}`}>
          {tier.highlighted && <div class="epx-pricing-card__badge">Recommended</div>}
          <h3 class="epx-pricing-card__name">{tier.name}</h3>
          <div class="epx-pricing-card__price-wrap">
            <span class="epx-pricing-card__price">{tier.price}</span>
            {tier.period && <span class="epx-pricing-card__period">{tier.period}</span>}
          </div>
          {tier.description && (
            <p class="epx-pricing-card__description">{tier.description}</p>
          )}
          <ul class="epx-pricing-card__features">
            {tier.features.split("\n").filter(Boolean).map((feat) => (
              <li class="epx-pricing-card__feature">
                <span class="epx-pricing-card__check" aria-hidden="true">✓</span>
                {feat.trim()}
              </li>
            ))}
          </ul>
          <a
            href={tier.ctaUrl}
            class={`epx-btn ${tier.highlighted ? "epx-btn--primary" : "epx-btn--outline"}`}
          >
            {tier.ctaLabel}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .epx-pricing { padding: 80px 0; }
  .epx-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .epx-section-header { text-align: center; margin-bottom: 48px; }
  .epx-section-title { font-size: 2rem; font-weight: 800; margin: 0 0 12px; }
  .epx-section-subtitle { font-size: 1.1rem; opacity: 0.7; margin: 0 auto; max-width: 560px; }

  .epx-pricing__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    align-items: stretch;
  }

  .epx-pricing-card {
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 16px;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
  }
  .epx-pricing-card.is-highlighted {
    border-color: #2563eb;
    box-shadow: 0 0 0 2px #2563eb, 0 8px 32px rgba(37,99,235,0.15);
  }
  .epx-pricing-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #2563eb;
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 20px;
    white-space: nowrap;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .epx-pricing-card__name { font-size: 1.2rem; font-weight: 700; margin: 0; }
  .epx-pricing-card__price-wrap { display: flex; align-items: baseline; gap: 4px; }
  .epx-pricing-card__price { font-size: 2.8rem; font-weight: 800; }
  .epx-pricing-card__period { font-size: 0.95rem; opacity: 0.6; }
  .epx-pricing-card__description { font-size: 0.9rem; opacity: 0.65; margin: 0; }
  .epx-pricing-card__features { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; flex: 1; }
  .epx-pricing-card__feature { display: flex; gap: 8px; font-size: 0.93rem; align-items: flex-start; }
  .epx-pricing-card__check { color: #2563eb; font-weight: 700; flex-shrink: 0; }

  .epx-btn {
    display: block;
    text-align: center;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: opacity 0.15s;
    margin-top: auto;
  }
  .epx-btn:hover { opacity: 0.85; }
  .epx-btn--primary { background: #2563eb; color: #fff; }
  .epx-btn--outline { border: 2px solid currentColor; background: transparent; }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--dark .epx-pricing-card { border-color: rgba(255,255,255,0.12); }
</style>
