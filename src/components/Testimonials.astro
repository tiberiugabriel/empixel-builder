---
import type { TestimonialsConfig } from "../types.js";
import { parseItems } from "../types.js";

interface Props {
  value: TestimonialsConfig;
}

const { value } = Astro.props;
const { headline, theme = "light" } = value;
const items = parseItems(value.items);
---

<section class={`epx-testimonials epx-theme--${theme}`}>
  <div class="epx-container">
    {headline && (
      <div class="epx-section-header">
        <h2 class="epx-section-title">{headline}</h2>
      </div>
    )}
    <div class="epx-testimonials__grid">
      {items.map((item) => (
        <div class="epx-testimonial-card">
          <p class="epx-testimonial-card__quote">"{item.quote}"</p>
          <div class="epx-testimonial-card__author">
            {item.avatarUrl && (
              <img src={item.avatarUrl} alt={item.author} class="epx-testimonial-card__avatar" loading="lazy" />
            )}
            <div class="epx-testimonial-card__meta">
              <span class="epx-testimonial-card__name">{item.author}</span>
              {(item.role || item.company) && (
                <span class="epx-testimonial-card__role">
                  {[item.role, item.company].filter(Boolean).join(", ")}
                </span>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .epx-testimonials { padding: 80px 0; }
  .epx-container { max-width: 1140px; margin: 0 auto; padding: 0 24px; }
  .epx-section-header { text-align: center; margin-bottom: 48px; }
  .epx-section-title { font-size: 2rem; font-weight: 800; margin: 0; }

  .epx-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 900px) { .epx-testimonials__grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .epx-testimonials__grid { grid-template-columns: 1fr; } }

  .epx-testimonial-card {
    padding: 28px;
    border-radius: 12px;
    border: 1px solid rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .epx-testimonial-card__quote {
    font-size: 1rem;
    line-height: 1.7;
    font-style: italic;
    margin: 0;
    flex: 1;
    opacity: 0.85;
  }
  .epx-testimonial-card__author { display: flex; align-items: center; gap: 12px; }
  .epx-testimonial-card__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .epx-testimonial-card__meta { display: flex; flex-direction: column; gap: 2px; }
  .epx-testimonial-card__name { font-weight: 700; font-size: 0.95rem; }
  .epx-testimonial-card__role { font-size: 0.85rem; opacity: 0.6; }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--dark .epx-testimonial-card { border-color: rgba(255,255,255,0.1); }
</style>
