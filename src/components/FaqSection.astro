---
import type { FaqConfig } from "../types.js";
import { parseItems } from "../types.js";

interface Props {
  value: FaqConfig;
}

const { value } = Astro.props;
const { headline, subheadline, theme = "light" } = value;
const items = parseItems(value.items);
---

<section class={`epx-faq epx-theme--${theme}`}>
  <div class="epx-faq__container epx-container">
    {(headline || subheadline) && (
      <div class="epx-section-header">
        {headline && <h2 class="epx-section-title">{headline}</h2>}
        {subheadline && <p class="epx-section-subtitle">{subheadline}</p>}
      </div>
    )}
    <div class="epx-faq__list">
      {items.map((item, i) => (
        <details class="epx-faq__item" name="epx-faq">
          <summary class="epx-faq__question">
            <span>{item.question}</span>
            <span class="epx-faq__arrow" aria-hidden="true">▾</span>
          </summary>
          <div class="epx-faq__answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .epx-faq { padding: 80px 0; }
  .epx-container { max-width: 760px; margin: 0 auto; padding: 0 24px; }
  .epx-section-header { text-align: center; margin-bottom: 48px; }
  .epx-section-title { font-size: 2rem; font-weight: 800; margin: 0 0 12px; }
  .epx-section-subtitle { font-size: 1.1rem; opacity: 0.7; margin: 0 auto; max-width: 560px; }

  .epx-faq__list { display: flex; flex-direction: column; }

  .epx-faq__item {
    border-bottom: 1px solid rgba(0,0,0,0.1);
  }
  .epx-faq__item:first-child { border-top: 1px solid rgba(0,0,0,0.1); }

  .epx-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    cursor: pointer;
    font-weight: 600;
    font-size: 1rem;
    list-style: none;
    gap: 16px;
  }
  .epx-faq__question::-webkit-details-marker { display: none; }
  .epx-faq__question span { flex: 1; }

  .epx-faq__arrow {
    flex-shrink: 0;
    transition: transform 0.2s;
    font-size: 1.1rem;
  }
  details[open] .epx-faq__arrow { transform: rotate(180deg); }

  .epx-faq__answer {
    padding-bottom: 20px;
  }
  .epx-faq__answer p {
    margin: 0;
    font-size: 0.97rem;
    line-height: 1.7;
    opacity: 0.75;
  }

  .epx-theme--light { background: #fff; color: #111; }
  .epx-theme--dark { background: #111; color: #fff; }
  .epx-theme--dark .epx-faq__item { border-color: rgba(255,255,255,0.12); }
</style>
