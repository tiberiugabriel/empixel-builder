---
import type { ButtonConfig } from "../types.js";
import { buildBlockChromeCss } from "./styleUtils.js";

interface Props {
  value: ButtonConfig;
  blockId?: string;
}

const { value, blockId } = Astro.props;
const cfg = value as Record<string, unknown>;

const advanced = cfg.advanced as Record<string, string> | undefined;
const cssId = advanced?.cssId || undefined;
const cssClasses = advanced?.cssClasses || undefined;

const text = value.text || "Click me";
const icon = value.icon ?? {};
const iconSrc = icon.iconSrc?.storageKey
  ? `/_emdash/api/media/file/${icon.iconSrc.storageKey}`
  : undefined;
const iconAlt = icon.iconSrc?.alt ?? "";
const iconSize = icon.iconSize || "16px";
const iconPos = icon.iconPosition ?? "left";
const iconColor = icon.iconColor;

// Link attrs
const linkHref = value.linkHref || undefined;
const linkTarget = value.linkNewTab ? "_blank" : undefined;
const linkRel = (() => {
  const parts: string[] = [];
  if (value.linkNewTab) parts.push("noopener", "noreferrer");
  if (value.linkNofollow) parts.push("nofollow");
  return parts.length ? parts.join(" ") : undefined;
})();
const linkCustomAttrs: Record<string, string> = {};
if (value.linkCustomAttr) {
  for (const pair of value.linkCustomAttr.split(",")) {
    const sep = pair.indexOf("|");
    if (sep > 0) {
      const k = pair.slice(0, sep).trim();
      const v = pair.slice(sep + 1).trim();
      if (k) linkCustomAttrs[k] = v;
    }
  }
}

const flexDir = (() => {
  if (iconPos === "top")    return "column";
  if (iconPos === "bottom") return "column-reverse";
  if (iconPos === "right")  return "row-reverse";
  return "row";
})();

const chromeCss = buildBlockChromeCss(cfg, blockId);

const flexCss = blockId
  ? `[data-epx-block="${blockId}"]{display:inline-flex;align-items:center;gap:6px;flex-direction:${flexDir};text-decoration:none;}`
  : "";

const allCss = [flexCss, chromeCss].filter(Boolean).join("");

const Tag = (linkHref ? "a" : "button") as astroHTML.JSX.HTMLTag;
---

<Tag
  data-epx-block={blockId || undefined}
  id={cssId}
  class={cssClasses || undefined}
  href={linkHref}
  target={linkTarget}
  rel={linkRel}
  type={!linkHref ? "button" : undefined}
  {...linkCustomAttrs}
>
  {iconSrc && (
    <img
      src={iconSrc}
      alt={iconAlt}
      style={`width:${iconSize};height:${iconSize};${iconColor ? `color:${iconColor};` : ""}`}
      loading="lazy"
      decoding="async"
    />
  )}
  <span>{text}</span>
</Tag>

{allCss && <style set:html={allCss} is:global />}
