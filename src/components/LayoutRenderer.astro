---
import type { SectionBlock } from "../types.js";
import BlockRenderer from "./BlockRenderer.astro";
import SectionContainer from "./SectionContainer.astro";
import { coalesceLayoutCss } from "./styleUtils.js";

// F4.4 follow-up — host page's resolved entry, threaded down from
// `BuilderWrapper.astro` and forwarded to every leaf via
// `BlockRenderer.astro`. Only the `field-binding` dispatch in
// `BlockRenderer.astro` actually reads it; every other branch ignores
// the prop. Optional — layouts rendered without an entry context still
// work (the leaf falls through to an unbound empty element).
//
// Defined inline (KISS — see `BuilderWrapper.astro` for the same
// shape; if a 4th file ever references it we extract to a shared module).
interface BuilderEntryRef {
  data?: Record<string, unknown>;
  edit?: Record<string, unknown>;
}

interface Props {
  sections: SectionBlock[];
  entry?: BuilderEntryRef | null;
}

const { sections, entry } = Astro.props;
const hasBlocks = sections.length > 0;

// F1.3 — Plugin-scoped reset emitted once per layout.
//
// Many EmDash host themes ship a global `* { box-sizing: border-box }` plus
// margin / padding resets that bleed onto plugin blocks (`<figure>`,
// `<button>`, `<a>`, etc.) and produce inconsistent results across sites.
// We emit a tiny reset scoped to `[data-epx-block]` and its descendants so
// the plugin's CSS pipeline always has a predictable starting point —
// regardless of what the host's global styles do.
//
// Skipped when `sections.length === 0` so empty layouts stay zero-emit.
const resetCss =
  "[data-epx-block]{box-sizing:border-box;margin:0;}" +
  "[data-epx-block] *,[data-epx-block] *::before,[data-epx-block] *::after{box-sizing:border-box;}";

// F4.1 — Per-block CSS collection.
//
// Pre-F4.1 every leaf block component emitted its own `<style is:global>`
// at template position; a 30-block page shipped 30+ inline `<style>` tags,
// each repeating its own `@media (max-width: ...)` block. F4.1 collapses
// the lot into a single `<style>` per page with grouped `@media` queries.
//
// Mechanism: `Astro.locals.empixelLayoutCss` is a shared string array. The
// LayoutRenderer (this file) initializes it BEFORE rendering any children;
// each block component pushes its CSS string into the array in its own
// frontmatter (instead of emitting a `<style>` tag at template position);
// the LayoutRenderer drains the array AFTER the iteration and emits one
// coalesced `<style is:global>`.
//
// Astro semantics: child component frontmatter executes synchronously when
// the parent's template encounters the component (via `{sections.map(...)}`).
// JSX expressions in the parent template are evaluated top-to-bottom, so
// the `<style>` tag below — placed AFTER the iteration — sees a fully
// populated array. SSR streaming preserves this ordering.
//
// We DON'T `delete Astro.locals.empixelLayoutCss` after — Astro creates a
// fresh `locals` per request, so the array is naturally request-scoped. The
// reset CSS (F1.3) is folded into the same coalesced bundle so the page
// emits exactly one `<style>` rather than reset + bundle.
type EpxLocals = { empixelLayoutCss?: string[] };
const epxLocals = Astro.locals as unknown as EpxLocals;
epxLocals.empixelLayoutCss = [];
if (hasBlocks) {
  epxLocals.empixelLayoutCss.push(resetCss);
}
---

{sections.map((block) => {
  if (block.type === "container") {
    return <SectionContainer value={block.config} children={block.children ?? []} blockId={block.id} />;
  }
  return <BlockRenderer block={block} entry={entry} />;
})}

{hasBlocks && (() => {
  const collected = epxLocals.empixelLayoutCss ?? [];
  const bundle = coalesceLayoutCss(collected);
  return bundle ? <style set:html={bundle} is:global /> : null;
})()}
