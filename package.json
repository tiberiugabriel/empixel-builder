{
  "name": "empixel-builder",
  "version": "0.6.0",
  "description": "Professional page builder for EmDash and Astro",
  "author": "Tiberiu Gabriel",
  "license": "GPL-3.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tiberiugabriel/empixel-builder.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "empixel-builder": "./dist/add.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src/components",
    "src/types.ts",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./admin": {
      "types": "./dist/admin/index.d.ts",
      "import": "./dist/admin/index.js"
    },
    "./astro": "./src/components/index.ts"
  },
  "peerDependencies": {
    "astro": ">=6.0.0",
    "better-sqlite3": ">=9.0.0",
    "emdash": ">=0.4.0",
    "@emdash-cms/admin": "*",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@emdash-cms/admin": {
      "optional": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "scripts": {
    "lint": "eslint src/",
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.59.0"
  }
}
